---
import type { Dict } from '../i18n/es';

interface Props {
  t: Dict;
}

const { t } = Astro.props;
---

<!-- Encabezado -->
<header class="px-margin-mobile lg:px-margin-desktop mb-24 max-w-screen-2xl mx-auto pt-8">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
    <div class="md:col-span-8">
      <h1 class="font-headline text-headline-xl uppercase">{t.exhibitions.title}</h1>
      <p class="font-mono text-label-mono text-graphite dark:text-silver mt-4 max-w-md">
        {t.exhibitions.intro}
      </p>
    </div>
  </div>
</header>

<!-- Listado -->
<section class="px-margin-mobile lg:px-margin-desktop max-w-screen-2xl mx-auto">
  <div class="flex flex-col">
    {
      t.exhibitions.rows.map((row, i) => (
        <div
          class:list={[
            'exhibition-row reveal-up border-t border-void-black/10 dark:border-paper-white/10 py-12 transition-colors duration-500 hover:bg-gallery-grey dark:hover:bg-iron-grey',
            i === t.exhibitions.rows.length - 1 && 'border-b',
          ]}
        >
          <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-baseline">
            <div class="md:col-span-2">
              <span class="exhibition-year font-mono text-label-mono text-graphite dark:text-silver block">
                {row.year}
              </span>
            </div>
            <div class="md:col-span-5 mt-2 md:mt-0">
              <h3 class="font-headline text-headline-md uppercase">{row.name}</h3>
              <p class="font-mono text-label-mono text-graphite dark:text-silver mt-1">{row.kind}</p>
            </div>
            <div class="md:col-span-5 mt-4 md:mt-0 text-left md:text-right">
              <p class="font-mono text-label-mono uppercase tracking-tighter">{row.venue}</p>
              <p class="font-mono text-label-mono text-graphite dark:text-silver">{row.place}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<!-- Catálogos -->
<section class="mt-32 mb-32 px-margin-mobile lg:px-margin-desktop max-w-screen-2xl mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
    <div class="md:col-span-7">
      <div class="aspect-[16/9] bg-gallery-grey dark:bg-iron-grey relative overflow-hidden flex items-center justify-center transition-colors duration-300">
        <img
          src="/images/obra-3.jpg"
          alt={t.exhibitions.anchorAlt}
          class="w-3/4 h-3/4 object-cover"
        />
      </div>
    </div>
    <div class="md:col-span-5 flex flex-col justify-end mt-12 md:mt-0">
      <h4 class="font-mono text-label-mono uppercase mb-4 tracking-[0.2em]">
        {t.exhibitions.catalogTitle}
      </h4>
      <p class="font-body text-body-md text-graphite dark:text-silver mb-8">
        {t.exhibitions.catalogText}
      </p>
      <a
        href={`mailto:${t.contact.email}`}
        class="inline-flex items-center justify-between border border-void-black dark:border-paper-white px-6 py-4 font-mono text-label-mono uppercase group transition-colors duration-300 hover:bg-void-black hover:text-paper-white dark:hover:bg-paper-white dark:hover:text-void-black"
      >
        <span>{t.exhibitions.catalogCta}</span>
        <span class="material-symbols-outlined ml-4 group-hover:translate-x-2 transition-transform" aria-hidden="true">
          arrow_forward
        </span>
      </a>
    </div>
  </div>
</section>
